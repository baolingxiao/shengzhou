# --- 登录（MVP 单用户，默认 admin / jarvis）---
JARVIS_AUTH_USER=admin
JARVIS_AUTH_PASSWORD=jarvis

# --- 服务端口 ---
NEURALPAL_BACKEND_PORT=8766

# --- 主对话 LLM（doubao 推荐；与百事通共用同一套密钥即可）---
NEURALPAL_LLM_PROVIDER=doubao
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_PRO=doubao-seed-2-0-pro-260215
DOUBAO_MODEL_LITE=doubao-seed-2-0-lite-260215
DOUBAO_MODEL_DEEP=doubao-seed-2-0-pro-260215
DOUBAO_MODEL_CODE=doubao-seed-2-0-code-preview-260215
DOUBAO_MAX_TOKENS=4096

# --- 可选 Claude（本迁移版未使用杂志/话题模块，可留空）---
ANTHROPIC_API_KEY=

# --- 沈昼 · 本机/网页代办（Computer Use）---
NEURALPAL_AGENT_ENABLED=true
# 设为 true 时不实际操作键鼠，仅模拟执行（验收 Step 1 时可先用）
NEURALPAL_AGENT_MOCK_MODE=false
NEURALPAL_AGENT_MAX_STEPS=20
# 本机执行模型（留空则用 ANTHROPIC_MODEL_SONNET）
NEURALPAL_AGENT_CLAUDE_MODEL=
NEURALPAL_AGENT_CLAUDE_MAX_TOKENS=4096
# 网页任务（OpenAI CUA；未配置则回退到本机 Safari + Claude）
OPENAI_API_KEY=
NEURALPAL_AGENT_OPENAI_MODEL=computer-use-preview

# --- OpenAI Realtime 语音对话（WebRTC）---
# 后端用真实 Key 签发 ephemeral token；前端永不接触真实 Key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
# 语速倍率：1.0 默认，范围 0.25～1.5；略快可设 1.1～1.15
OPENAI_REALTIME_SPEED=1.1
# 设为 true 启用 Realtime Voice Chat；false 则回退旧 STT→LLM→TTS 链路
VITE_ENABLE_REALTIME_VOICE=true
NEURALPAL_AGENT_STATE_DIR=data/agent_sessions
# 开发模式：允许从 Terminal/Python 启动时代操（系统设置里显示 Python，非「贾维斯」）
# 正式使用请构建 dist/贾维斯.app，不要开启此项
# NEURALPAL_ALLOW_TERMINAL_AGENT=true

# --- PWA 桌面渠道 & 更新确认 ---
NEURALPAL_DESKTOP_UPDATE_CHECK_ENABLED=true
NEURALPAL_DESKTOP_UPDATE_CHECK_INTERVAL_SECONDS=3600
NEURALPAL_UPDATE_GIT_REMOTE=origin
# 留空则使用当前 git 分支
NEURALPAL_UPDATE_GIT_BRANCH=
NEURALPAL_DESKTOP_UPDATE_SCRIPT=scripts/restart_desktop_app.sh
NEURALPAL_DESKTOP_UPDATE_STATE_PATH=data/desktop_update_state.json

# 前端可选：更新轮询间隔（秒），需在 .env 中 VITE_ 前缀供 Vite 读取
# VITE_UPDATE_CHECK_INTERVAL_SECONDS=3600
# VITE_APP_CHANNEL=pwa

# --- Claude 模型 ID（主对话 provider=claude 时使用）---
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# --- 对话行为 ---
NEURALPAL_WORKING_MEMORY_MAX_ROUNDS=5
NEURALPAL_LOCAL_USE_MEMORY_ORCH=true
NEURALPAL_COMPLIANCE_REVIEW_ENABLED=true
NEURALPAL_REMINDER_ENABLED=false
NEURALPAL_APPEND_PDF_APPENDIX=false

# --- 记忆宫殿（沈昼角色目录，与聊天/后台 UI 共用）---
NEURALPAL_KNOWLEDGE_PALACE=data/characters/沈昼/knowledge_palace
NEURALPAL_LONG_TERM_CHROMA_PATH=data/characters/沈昼/chroma_db
NEURALPAL_MEMORY_AUTO_ARCHIVE=true
NEURALPAL_MEMORY_MAINTENANCE_ENABLED=true

# --- 沈昼世界引擎集成（一气化三清 / shenzhou-world）---
SHENZHOU_INTEGRATION_ENABLED=true
SHENZHOU_WORLD_API_URL=http://127.0.0.1:3000
# 与 shenzhou-world 的 SHENZHOU_INTERNAL_TOKEN 保持一致
SHENZHOU_INTERNAL_TOKEN=change-me-to-a-long-random-string
SHENZHOU_USER_ENTITY_SLUG=dai-jinxin
SHENZHOU_USER_DISPLAY_NAME=戴金鑫
SHENZHOU_DEFAULT_SESSION_ID=user-admin
SHENZHOU_TIMEZONE=Asia/Shanghai
# 23:59 用户日结 → 00:05 世界流水线 → 00:15 拉取生活上下文
SHENZHOU_SYNC_HOUR=23
SHENZHOU_SYNC_MINUTE=59
SHENZHOU_PIPELINE_HOUR=0
SHENZHOU_PIPELINE_MINUTE=5
SHENZHOU_PULL_HOUR=0
SHENZHOU_PULL_MINUTE=15
# --- 云端部署（方案 B · 中心机）---
# 复制本文件为 .env 后取消注释并填写密钥；内测用户只通过浏览器/PWA 访问
# JARVIS_APP_MODE=1
# NEURALPAL_BIND=0.0.0.0
# NEURALPAL_DESKTOP_UPDATE_CHECK_ENABLED=false
# NEURALPAL_AGENT_ENABLED=false
# NEURALPAL_VOICE_STT_PROVIDER=openai

# --- 角色数据（默认 data/characters/）---
# CHARACTERS_DATA_PATH=data/characters/characters.json

# --- 语音 STT（默认 local = 本地 faster-whisper，免费）---
NEURALPAL_VOICE_STT_PROVIDER=local
NEURALPAL_VOICE_STT_LOCAL_MODEL=base
NEURALPAL_VOICE_STT_LANGUAGE=zh
NEURALPAL_VOICE_WAKE_PHRASES=在不,再不,仔不
NEURALPAL_VOICE_SILENCE_SECONDS=1.2
NEURALPAL_VOICE_MIN_SPEECH_SECONDS=0.4
NEURALPAL_VOICE_WAKE_TIMEOUT_SECONDS=8
NEURALPAL_VOICE_FOLLOWUP_SECONDS=30

# --- 语音 TTS（ElevenLabs，语音对话需配置）---
NEURALPAL_REPLY_TTS_ENABLED=true
NEURALPAL_REPLY_TTS_CHUNK_CHARS=180
NEURALPAL_REPLY_TTS_CACHE_DIR=data/reply_tts_cache
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/text-to-speech
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_SECONDS=35

# --- 可选：聊天背景图（Pexels）---
# NEURALPAL_CHAT_BACKGROUND_ENABLED=true
# PEXELS_API_KEY=
