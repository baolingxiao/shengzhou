{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/execution-trace.json",
  "title": "Jarvis Execution Trace",
  "type": "object",
  "required": [
    "trace_id",
    "created_at",
    "user_input",
    "session_id",
    "character_id",
    "timings",
    "prompt",
    "memory",
    "llm",
    "postprocess",
    "tts",
    "errors"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 8 },
    "created_at": { "type": "string", "format": "date-time" },
    "user_input": { "type": "string" },
    "session_id": { "type": "string" },
    "character_id": { "type": "string" },
    "timings": {
      "type": "object",
      "required": [
        "total_ms",
        "preprocess_ms",
        "memory_ms",
        "prompt_build_ms",
        "route_ms",
        "llm_ms",
        "compliance_ms",
        "postprocess_ms",
        "tts_total_ms"
      ],
      "properties": {
        "total_ms": { "type": "number", "minimum": 0 },
        "preprocess_ms": { "type": "number", "minimum": 0 },
        "memory_ms": { "type": "number", "minimum": 0 },
        "prompt_build_ms": { "type": "number", "minimum": 0 },
        "route_ms": { "type": "number", "minimum": 0 },
        "llm_ms": { "type": "number", "minimum": 0 },
        "compliance_ms": { "type": "number", "minimum": 0 },
        "postprocess_ms": { "type": "number", "minimum": 0 },
        "tts_total_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "prompt": {
      "type": "object",
      "required": ["system_prompt", "messages"],
      "properties": {
        "system_prompt": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "required": ["short_term", "long_term", "chroma_results"],
      "properties": {
        "short_term": { "type": "array" },
        "long_term": { "type": "array" },
        "chroma_results": { "type": "array" }
      }
    },
    "llm": {
      "type": "object",
      "required": ["provider", "model", "parameters", "raw_response", "final_response"],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "parameters": { "type": "object" },
        "raw_response": { "type": "string" },
        "final_response": { "type": "string" }
      }
    },
    "postprocess": {
      "type": "object",
      "required": ["segments", "final_text_for_tts"],
      "properties": {
        "segments": { "type": "array", "items": { "type": "string" } },
        "final_text_for_tts": { "type": "string" }
      }
    },
    "tts": {
      "type": "object",
      "required": ["enabled", "provider", "model", "chunks"],
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["index", "text", "request_ms", "audio_duration_ms", "played"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "text": { "type": "string" },
              "request_ms": { "type": "number", "minimum": 0 },
              "audio_duration_ms": { "type": "number", "minimum": 0 },
              "played": { "type": "boolean" },
              "cached": { "type": "boolean" },
              "play_start_at": { "type": "string" },
              "play_end_at": { "type": "string" }
            }
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "description": "扩展字段：预处理快照、前后端时间戳、API 响应",
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "error"],
        "properties": {
          "step": { "type": "string" },
          "error": { "type": "string" },
          "type": { "type": "string" },
          "at": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
